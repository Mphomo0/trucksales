generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model users {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model inventory {
  id              String    @id @default(cuid())
  name            String
  make            String
  model           String
  year            Int
  registrationNo String?
  vatPrice        Float
  pricenoVat       Float
  mileage        Float?
  fuelType       String?
  condition      String
  transmission   String?
  images         Json
  videoLink      String?
  description    String
  bodyType       String?
  truckSize      String?
  slug           String    @unique
  specialPrice   Float?
  specialValidFrom DateTime?
specialValidTo   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([make])
  @@index([model])
  @@index([bodyType])
  @@index([truckSize])
  @@index([vatPrice])
  @@index([condition])
}

model spares {
  id             String   @id @default(cuid())
  name           String
  description    String
  make           String
  price          Float
  noVatPrice     Float?
  condition      String
  category      String
  images         Json
  videoLink     String?
  slug          String   @unique
  specialPrice  Float?
  specialPriceNoVat Float?
  specialValidFrom DateTime?
  specialValidTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([make])
  @@index([category])
  @@index([price])
  @@index([condition])
  @@index([createdAt(sort: Desc)])
}