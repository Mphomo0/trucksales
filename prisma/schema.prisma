generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model users {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model inventory {
  id              String    @id @default(cuid())
  name            String
  make            String
  model           String
  year            Int
  registrationNo String?
  vatPrice        Float
  pricenoVat       Float
  mileage        Float?
  fuelType       String?
  condition      String
  transmission   String?
  images         Json
  videoLink      String?
  description    String
  bodyType       String?
  truckSize      String?
  slug           String    @unique
  specialPrice   Float?
  specialValidFrom DateTime?
specialValidTo   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([make])
  @@index([model])
  @@index([bodyType])
  @@index([truckSize])
  @@index([vatPrice])
  @@index([condition])
}

model spares {
  id             String   @id @default(cuid())
  name           String
  description    String
  make           String
  price          Float
  noVatPrice     Float?
  condition      String
  category      String
  images         Json
  videoLink     String?
  slug          String   @unique
  specialPrice  Float?
  specialPriceNoVat Float?
  specialValidFrom DateTime?
  specialValidTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([make])
  @@index([category])
  @@index([price])
  @@index([condition])
  @@index([createdAt(sort: Desc)])
}

model WebsiteContentChunk {
  id          String   @id @default(cuid())

  url         String
  title       String?
  content     String

  contentHash String

  pageType    String

  indexedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([url])
  @@index([contentHash])
  @@index([pageType])
}

model ChatSession {
  id        String   @id @default(cuid())

  sessionId String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt DateTime

  messages  ChatMessage[]

  @@index([expiresAt])
}

model ChatMessage {
  id        String   @id @default(cuid())

  sessionId String

  role      String

  message   String

  createdAt DateTime @default(now())

  expiresAt DateTime

  session   ChatSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
  @@index([expiresAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model ChatLead {
  id                String     @id @default(cuid())

  name              String
  phone             String
  email             String?

  interestedVehicle String?
  vehicleId         String?

  message           String?

  status            LeadStatus @default(NEW)

  source            String     @default("chatbot")

  emailSent         Boolean    @default(false)

  emailError        String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  expiresAt         DateTime

  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([emailSent])
}

model IndexingLog {
  id            String   @id @default(cuid())

  status        String

  startedAt     DateTime @default(now())

  finishedAt    DateTime?

  pagesIndexed  Int?

  chunksCreated Int?
  chunksUpdated Int?
  chunksDeleted Int?
  chunksSkipped Int?

  error         String?

  @@index([status])
  @@index([startedAt])
}